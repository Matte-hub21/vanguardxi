# Supabase Configuration
# Get these values from: https://app.supabase.com/projects
# 1. Go to Project Settings → API
# 2. Copy "Project URL" and paste below as NEXT_PUBLIC_SUPABASE_URL
# 3. Copy "anon public" key and paste below as NEXT_PUBLIC_SUPABASE_ANON_KEY

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Authentication
# Set to "false" when using real Supabase
# Set to "true" to use mock in-memory database (for development)
NEXT_PUBLIC_USE_MOCK_AUTH=true

# Development Only
NODE_OPTIONS=--max-old-space-size=512
