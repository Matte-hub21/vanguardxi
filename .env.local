# ============================================
# VANGUARD XI - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your actual values

# ============================================
# AUTHENTICATION MODE
# ============================================
# Set to 'true' to use mock authentication (no Supabase required)
# Set to 'false' to use real Supabase authentication
NEXT_PUBLIC_USE_MOCK_AUTH=true

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Required only if NEXT_PUBLIC_USE_MOCK_AUTH=false
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://mhtwaqzpwuvujohwcrxg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1odHdhcXpwd3V2dWpvaHdjcnhnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE1OTM3MTAsImV4cCI6MjA5NzE2OTcxMH0.lzr1Uf38O0e70pUWASl9N1FJZ3KOcwc06J5IqagD0SY
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# AI/OCR CONFIGURATION
# ============================================
# Emergent Universal LLM Key for GPT-4 Vision OCR
# Get your key from: https://emergentagent.com
EMERGENT_LLM_KEY=your-emergent-llm-key-here

# OCR Provider (optional, defaults to 'openai')
# Options: 'openai' or 'gemini'
OCR_PROVIDER=openai

# ============================================
# API CONFIGURATION
# ============================================
# Base URL for API calls (used in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS Origins (optional, defaults to *)
CORS_ORIGINS=*
