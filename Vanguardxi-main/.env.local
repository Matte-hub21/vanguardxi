# ============================================
# VANGUARD XI - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your actual values

# ============================================
# AUTHENTICATION MODE
# ============================================
# Set to 'true' to use mock authentication (no Supabase required)
# Set to 'false' to use real Supabase authentication
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Required only if NEXT_PUBLIC_USE_MOCK_AUTH=false
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://yvdfvlzaodmfavtznbke.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2ZGZ2bHphb2RtZmF2dHpuYmtlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg2Nzc4ODQsImV4cCI6MjA5NDI1Mzg4NH0.gYLVKbOZbV1vP2vsV7m7TsdPx8o7AxecPbbsVzSS6Wo
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2ZGZ2bHphb2RtZmF2dHpuYmtlIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODY3Nzg4NCwiZXhwIjoyMDk0MjUzODg0fQ.LBiGGJStImz_zTLDtKEWUzYLohv3jURraCIpkgGcL3M
# ============================================
# AI/OCR CONFIGURATION
# ============================================
# Emergent Universal LLM Key for GPT-4 Vision OCR
# Get your key from: https://emergentagent.com
EMERGENT_LLM_KEY=your-emergent-llm-key-here

# OCR Provider (optional, defaults to 'openai')
# Options: 'openai' or 'gemini'
OCR_PROVIDER=openai

# ============================================
# API CONFIGURATION
# ============================================
# Base URL for API calls (used in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS Origins (optional, defaults to *)
CORS_ORIGINS=*
